# ===== PROXY SERVER =====
PORT=3001
NODE_ENV=production

# ===== INBOUND AUTH (who can call YOUR proxy) =====
# Modes: 'bearer' | 'api-key' | 'none' (dev only)
AUTH_MODE=bearer
ALLOWED_TOKENS=sk-vear-proxy-token-change-me

# ===== UPSTREAM — ANONYMOUS MODE (DEFAULT) =====
# No config needed. The proxy auto-fetches auth tokens from ve@r.
# Works out of the box as an anonymous guest (IP-based rate limit applies).

# ===== UPSTREAM — COOKIE POOL (OPTIONAL BOOST) =====
# Add PHPSESSID cookies from ve@r to bypass the anonymous rate limit.
# Get them from your browser: DevTools → Application → Cookies → PHPSESSID
# Paste just the VALUE (not the name, not PHPSESSID=)
# Separate multiple cookies with commas for round-robin rotation.
# Each cookie = a separate session with its own daily quota.
#
# Example (single cookie):
# VEAR_COOKIE=abc123def456ghi789
#
# Example (multiple cookies for rotation):
# VEAR_COOKIE=abc123def456ghi789,jkl012mno345pqr678,stu901vwx234yza567

# ===== LOGGING =====
LOG_LEVEL=info
LOG_REQUEST_BODIES=false