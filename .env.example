# ===== PROXY SERVER =====
PORT=3001
NODE_ENV=production

# ===== INBOUND AUTH (who can call YOUR proxy) =====
# Modes: 'bearer' | 'api-key' | 'none' (dev only)
AUTH_MODE=bearer
ALLOWED_TOKENS=sk-vear-proxy-token-change-me

# ===== UPSTREAM — ANONYMOUS MODE (DEFAULT) =====
# No config needed. The proxy auto-fetches auth tokens from ve@r.
# Works out of the box as an anonymous guest (IP-based rate limit applies).

# ===== UPSTREAM — COOKIE POOL (OPTIONAL BOOST) =====
# Add your user_auth cookie from ve@r to bypass the anonymous rate limit.
# Get it from your browser: DevTools → Application → Cookies → user_auth
# Paste just the VALUE (not the name)
# Separate multiple accounts with commas for round-robin rotation.
# Each user_auth = a logged-in account with its own daily quota.
#
# Example (single account):
# VEAR_USER_AUTH=cUY1RHlwVUo3WmFZ...
#
# Example (multiple accounts for rotation):
# VEAR_USER_AUTH=cUY1RHlwVUo3WmFZ...,dkx2UkpxVVo0WmFH...

# ===== LOGGING =====
LOG_LEVEL=info
LOG_REQUEST_BODIES=false