# ===== PROXY SERVER =====
PORT=3001
NODE_ENV=production

# ===== INBOUND AUTH (who can call YOUR proxy) =====
# Modes: 'bearer' | 'api-key' | 'none' (dev only)
AUTH_MODE=bearer
ALLOWED_TOKENS=sk-vear-proxy-token-change-me

# ===== UPSTREAM PROVIDER KEYS (who YOUR proxy calls) =====
# Get your session cookie from vear.com (PHPSESSID). Do not include PHPSESSID=.
# You can define multiple cookies separated by a comma. The proxy will pick one randomly per request.
VEAR_COOKIE=

# ===== LOGGING =====
LOG_LEVEL=info
LOG_REQUEST_BODIES=false