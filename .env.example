# ===== PROXY SERVER =====
PORT=3001
NODE_ENV=production

# ===== INBOUND AUTH (who can call YOUR proxy) =====
# Modes: 'bearer' | 'api-key' | 'none' (dev only)
AUTH_MODE=bearer
ALLOWED_TOKENS=sk-vear-proxy-token-change-me

# ===== UPSTREAM (ZERO CONFIG — NO API KEYS OR COOKIES NEEDED) =====
# The proxy automatically fetches a _wt token from vear.com on each request.
# It also generates an HMAC-signed fingerprint using the key from vear.com's JS source.
# No manual configuration is required for upstream access.

# ===== LOGGING =====
LOG_LEVEL=info
LOG_REQUEST_BODIES=false